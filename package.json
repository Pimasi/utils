{
    "name": "@pimasi/utils",
    "version": "1.0.3",
    "private": false,
    "description": "The only utility library you'll ever need",
    "exports": {
        "./lib/error": {
            "types": "./lib/error/index.d.ts",
            "default": "./lib/error/index.js"
        },
        "./lib/helpers": {
            "types": "./lib/helpers/index.d.ts",
            "default": "./lib/helpers/index.js"
        },
        "./lib/http": {
            "types": "./lib/http/index.d.ts",
            "default": "./lib/http/index.js"
        },
        "./lib/json-schema": {
            "types": "./lib/json-schema/index.d.ts",
            "default": "./lib/json-schema/index.js"
        },
        "./lib/logger": {
            "types": "./lib/logger/index.d.ts",
            "default": "./lib/logger/index.js"
        },
        "./lib/observable": {
            "types": "./lib/observable/index.d.ts",
            "default": "./lib/observable/index.js"
        }
    },
    "files": [
        "lib/",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "test": "vitest run",
        "watch": "npm run build -- --watch",
        "build": "tsc -p tsconfig.build.json",
        "build:prod": "rm -rf lib && npm run build && vitest run --config vitest.config.lib.mts",
        "preversion": "npm run build:prod",
        "prepare": "husky"
    },
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/pimasi/utils.git"
    },
    "author": "simonpiscitelli@gmail.com",
    "license": "Apache-2.0",
    "bugs": {
        "url": "https://github.com/pimasi/utils/issues"
    },
    "homepage": "https://github.com/pimasi/utils#readme",
    "lint-staged": {
        "*.{ts,mts,json,md}": "prettier --write"
    },
    "devDependencies": {
        "@types/node": "^24.12.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1",
        "typescript": "^6.0.0",
        "vitest": "^3.2.4"
    },
    "dependencies": {
        "fast-safe-stringify": "=2.1.1",
        "jsonschema": "=1.5.0"
    }
}
