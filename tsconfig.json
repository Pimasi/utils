{
    "compilerOptions": {
        "target": "esnext",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "skipLibCheck": true,
        "types": ["node"],
        "declaration": true,
        "diagnostics": true,
        "incremental": true,
        "sourceMap": true,
        "outDir": "lib",
        "strict": true
    },
    "exclude": ["node_modules", "lib"]
}
